# 图床类型（github / s3）
PROVIDER_TYPE=github

# ===== GitHub 图床配置 =====
# GitHub Personal Access Token（获取方式：https://github.com/settings/tokens）
GITHUB_TOKEN=your_github_personal_access_token

# GitHub 用户名
GITHUB_USER=your_username

# 仓库名（用于存放图片）
GITHUB_REPO=your_repo

# 分支名（默认: master）
GITHUB_BRANCH=master

# 图片存放目录（默认: images）
GITHUB_IMAGES_DIR=images

# 路径模式：flat（平铺）或 date（按年/月/日，默认: flat）
# flat:    images/xxx.png
# date:    images/2026/01/12/xxx.png
GITHUB_PATH_MODE=flat

# ===== S3 图床配置（支持七牛云、阿里云 OSS、腾讯云 COS 等 S3 兼容存储）=====
# S3 Access Key ID
S3_ACCESS_KEY_ID=your_access_key_id

# S3 Secret Access Key
S3_SECRET_ACCESS_KEY=your_secret_access_key

# S3 Bucket 名称
S3_BUCKET=your_bucket

# S3 Endpoint（七牛云: s3.cn-south-1.qiniucs.com）
S3_ENDPOINT=s3.cn-south-1.qiniucs.com

# S3 Region（七牛云: cn-south-1）
S3_REGION=cn-south-1

# S3 存储目录前缀（可选，默认: images）
S3_IMAGES_DIR=images

# S3 路径模式（可选，默认: flat）
# flat:    images/xxx.png
# date:    images/2026/01/12/xxx.png
S3_PATH_MODE=flat

# 自定义域名（可选，用于 CDN 加速）
# S3_DOMAIN=https://cdn.example.com
